# =============================================================================
# Talon Environment Variables
# Copy to .env and fill in the values for your setup
# =============================================================================

# -- SurrealDB --
SURREALDB_USER=root
SURREALDB_PASS=root

# -- Gateway (talon-gateway, port 8080) --
ACTON_SURREALDB__URL=ws://localhost:8000
ACTON_SURREALDB__USERNAME=root
ACTON_SURREALDB__PASSWORD=root
RUST_LOG=info,talon_gateway=debug

# -- Web Channel (talon-web, port 8081) --
TALON_GATEWAY_URL=http://localhost:8080
TALON_WEB_PORT=8081
TALON_TENANT_ID=default

# -- Admin Dashboard (talon-admin, port 8082) --
TALON_ADMIN_GATEWAY_URL=http://localhost:8080
TALON_ADMIN_PORT=8082

# -- Telegram (optional) --
TELOXIDE_TOKEN=
TALON_TELEGRAM_GATEWAY_URL=http://localhost:8080
TALON_TELEGRAM_TENANT_ID=default

# -- Discord (optional) --
DISCORD_TOKEN=
TALON_DISCORD_GATEWAY_URL=http://localhost:8080
TALON_DISCORD_TENANT_ID=default

# -- Slack (optional) --
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
TALON_SLACK_GATEWAY_URL=http://localhost:8080
TALON_SLACK_TENANT_ID=default
